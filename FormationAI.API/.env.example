# Variables d'environnement à définir sur Railway (Settings > Variables)

# Fournie automatiquement par le plugin PostgreSQL de Railway
DATABASE_URL=postgres://user:password@host:5432/railway

# Clé secrète JWT (32 caractères minimum)
Jwt__Key=change_moi_par_une_cle_secrete_de_32c_minimum
Jwt__Issuer=FormationAI.API
Jwt__Audience=FormationAI.Client
Jwt__ExpireMinutes=120

# Clés des services IA
HeyGen__ApiKey=ta_cle_heygen
Anam__ApiKey=ta_cle_anam
